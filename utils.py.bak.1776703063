from typing import Dict, List, Tuple, Union

import hivemind
import torch
from petals import AutoDistributedModelForCausalLM
from transformers import AutoTokenizer, PreTrainedModel, PreTrainedTokenizer

import config
from data_structures import ModelConfig

logger = hivemind.get_logger(__file__)


def load_models() -> Dict[str, Tuple[PreTrainedModel, PreTrainedTokenizer, ModelConfig]]:
    models = {}
    for family in config.MODEL_FAMILIES.values():
        for model_config in family:
            backend_config = model_config.backend

            logger.info(f"Loading tokenizer for {backend_config.repository}")
            tokenizer = AutoTokenizer.from_pretrained(backend_config.repository, add_bos_token=False, use_fast=False)

            logger.info(
                f"Loading model {backend_config.repository} with adapter {backend_config.adapter} in {config.TORCH_DTYPE}"
            )
            # We set use_fast=False since LlamaTokenizerFast takes a long time to init
            model = AutoDistributedModelForCausalLM.from_pretrained(
                backend_config.repository,
                active_adapter=backend_config.adapter,
                torch_dtype=config.TORCH_DTYPE,
                initial_peers=config.INITIAL_PEERS,
                max_retries=3,
            )
            model = model.to(config.DEVICE)

            for key in [backend_config.key] + list(backend_config.aliases):
                models[key] = model, tokenizer, backend_config
    return models


def safe_decode(tokenizer: PreTrainedTokenizer, outputs: Union[torch.Tensor, List[int]]) -> str:
    # Workaround to make SentencePiece .decode() keep leading spaces in a token
    fake_token = tokenizer("^")["input_ids"][0]
    outputs = outputs.tolist() if isinstance(outputs, torch.Tensor) else outputs
    result = tokenizer.decode([fake_token] + outputs)

    # We use .lstrip() since SentencePiece may add leading spaces, e.g. if the outputs are "</s>"
    return result.lstrip()[1:]

# ============================================================
# Response post-processing: strip hedging / filler phrases
# ============================================================
import re as _re

_FILLER_PATTERNS = [
    _re.compile(r"However,?\s+it'?s\s+(also\s+)?important\s+to\s+note\s+that\s+", _re.IGNORECASE),
    _re.compile(r"(?:[Ii]t'?s|[Ii]t\s+is)\s+(also\s+)?important\s+to\s+note\s+(that\s+)?", _re.IGNORECASE),
    _re.compile(r"(?:[Ii]t'?s|[Ii]t\s+is)\s+(also\s+)?worth\s+(mentioning|noting)\s+(that\s+)?", _re.IGNORECASE),
    _re.compile(r"(This|That|Consumption|Amounts?|Numbers?|Figures?|Results?|Values?)\s+can\s+vary\s+widely[^.]*\.?", _re.IGNORECASE),
    _re.compile(r"however,?\s+this\s+can\s+vary[^.]*\.?", _re.IGNORECASE),
    _re.compile(r"[Ss]ome\s+(people|individuals|folks|users)\s+(may|might)\s+[^.]*?while\s+others\s+(might|may|do)\s+[^.]*?(?=\.|$)", _re.IGNORECASE | _re.DOTALL),
    _re.compile(r"\s*,?\s*(varies|varying)?\s*from\s+person\s+to\s+person", _re.IGNORECASE),
    _re.compile(r"[Ii]t\s+depends\s+on\s+the\s+person[^.]*\.?", _re.IGNORECASE),
    # Self-referential AI disclaimers (apostrophe-tolerant: ' or \u2019)
    _re.compile(r"I\s+don['\u2019]?t\s+have\s+personal\s+experiences", _re.IGNORECASE),
    _re.compile(r"I\s+don['\u2019]?t\s+have\s+emotions", _re.IGNORECASE),
    _re.compile(r"\bAs\s+an\s+AI\b", _re.IGNORECASE),
    _re.compile(r"\bAs\s+a\s+language\s+model\b", _re.IGNORECASE),
    _re.compile(r"\bI\s+cannot\s+feel\b", _re.IGNORECASE),
    _re.compile(r"I['\u2019]?m\s+just\s+an\s+AI", _re.IGNORECASE),
    _re.compile(r"\bI\s+am\s+an\s+AI\s+assistant\b", _re.IGNORECASE),
]

# Opening meta filter: drop a leading clause/sentence that describes what the
# model can or cannot do instead of answering. Applied only at the start of
# the response. Two shapes are handled:
#   (a) "<meta-clause>, but|however|still|yet|although|though <answer>"
#       -> strip the meta-clause and the connective, keep the answer.
#   (b) "<meta-sentence>. <answer>"
#       -> strip the whole leading sentence (up to the first .!?).
_META_OPENER = (
    r"(?:"
    r"As\s+an?\s+AI\b|"
    r"As\s+a\s+language\s+model\b|"
    r"I(?:['\u2019]m|\s+am)\s+(?:just\s+|only\s+)?an?\s+AI\b|"
    r"I(?:['\u2019]m|\s+am)\s+(?:just\s+|only\s+)?a\s+language\s+model\b|"
    r"I\s+(?:cannot|can['\u2019]?t|do\s+not|don['\u2019]?t)\s+"
    r"(?:feel|experience|have\s+(?:personal|emotions|feelings|opinions|experiences|preferences|beliefs|access|the\s+ability|the\s+capability)|access|provide\s+personal|physically|truly\s+understand|possess)|"
    r"I\s+am\s+(?:not\s+able|unable)\s+to\b|"
    r"I\s+don['\u2019]?t\s+have\s+(?:the\s+)?(?:ability|capability|capacity|personal|emotions|feelings|opinions|experiences|preferences)\b"
    r")"
)
_LEADIN = r"(?:(?:Unfortunately|However|Well|Actually|Please\s+note|Note|Of\s+course)[,.]?\s+)?"

# (a) clause form: meta-phrase, <optional non-terminator text>, but/however/... <answer>
_OPENING_META_CLAUSE = _re.compile(
    r"^\s*" + _LEADIN + _META_OPENER +
    r"[^.!?\n]*?,\s+(?:but|however|still|yet|although|though)\s+",
    _re.IGNORECASE,
)
# (b) full-sentence form: meta-sentence + terminator
_OPENING_META_SENTENCE = _re.compile(
    r"^\s*" + _LEADIN + _META_OPENER +
    r"[^.!?\n]*[.!?](?:\s+|\n|$)",
    _re.IGNORECASE,
)


def _strip_opening_meta_sentence(text):
    """Remove up to 2 leading meta-commentary clauses/sentences before the answer."""
    if not text:
        return text
    for _ in range(2):
        # Prefer clause form first so "X, but Y" keeps Y instead of being eaten whole
        new = _OPENING_META_CLAUSE.sub("", text, count=1)
        if new == text:
            new = _OPENING_META_SENTENCE.sub("", text, count=1)
        if new == text:
            break
        text = new
    # Capitalise first letter if the new lead starts with a lowercase word
    text = _re.sub(r"^(\s*)([a-z])", lambda m: m.group(1) + m.group(2).upper(), text, count=1)
    return text


# ============================================================
# URL stripping: sources are surfaced via the source-pill UI,
# so raw URLs in the response body are redundant clutter.
# ============================================================
_MD_LINK_URL_RE = _re.compile(r"\[([^\]]+)\]\(\s*https?://[^)\s]+\s*\)")
_ANGLE_URL_RE   = _re.compile(r"<\s*https?://[^>\s]+\s*>")
_BARE_URL_RE    = _re.compile(r"https?://[^\s<>)\]]+", _re.IGNORECASE)

# Heading that introduces a trailing References/Sources block. If the text
# from the heading onward contains a URL, the whole tail is treated as
# citation noise and stripped.
_REF_BLOCK_HEADING_RE = _re.compile(
    r"(?im)(?:^|\n|\s)"
    r"(?:\*\*|__)?\s*"
    r"(?:References?\s*\(?s?\)?|Sources?|Bibliography|Citations?|"
    r"Further\s+reading|Footnotes?)"
    r"\s*[:.\-]"
)

# "available at: <url>", "Source: url", "Retrieved from url" — strip the
# connector phrase together with its URL in one shot.
_URL_WITH_PREFIX_RE = _re.compile(
    r"(?i)(?:,\s*)?"
    r"\b(?:available\s+at|source|sources|see(?:\s+also)?|"
    r"retrieved\s+from|found\s+at|(?:read\s+)?more\s+(?:info(?:\s+at)?|details|at)|"
    r"full\s+(?:details|text|article|info)|"
    r"additional\s+(?:info|details|information)|"
    r"link(?:s)?|url|visit)"
    r"\s*[:\-]?\s*"
    r"(?:<\s*)?https?://[^\s<>)\]]+\s*>?",
)

# "[1] https://..." or "[1]: <https://...>" — strip marker + URL.
_REF_BRACKET_URL_RE = _re.compile(
    r"\[\s*\d{1,3}\s*\]\s*:?\s*(?:<\s*)?https?://[^\s<>)\]]+\s*>?"
)

# Dangling connector phrases that no longer have a URL after them
# (because we just stripped the URL). Only match at end-of-line/text.
_DANGLING_PREFIX_RE = _re.compile(
    r"(?im)(?:,\s*)?"
    r"\b(?:available\s+at|retrieved\s+from|found\s+at|"
    r"read\s+more\s+at|more\s+(?:info(?:\s+at)?|details|at)|"
    r"full\s+(?:details|text|article|info)|"
    r"additional\s+(?:info|details|information))"
    r"\s*[:\-]?\s*(?=[.,;]?\s*(?:\n|$))"
)
# "Source:" / "Sources:" at start of line with nothing meaningful after.
_DANGLING_SOURCE_LINE_RE = _re.compile(
    r"(?im)^\s*(?:\*\*|__)?\s*sources?\s*[:\-]\s*(?:\*\*|__)?\s*(?=[.,;]?\s*(?:\n|$))"
)

# Orphan bracketed reference numbers like "[1]" / "[12]" left behind after
# URL removal. Restrict to 1-2 digits so year markers "[2023]" survive.
_ORPHAN_REF_NUM_RE = _re.compile(r"\[\s*\d{1,2}\s*\]")


def _strip_trailing_ref_block(text):
    """If a References:/Sources:/Bibliography heading is followed by a URL
    anywhere in the tail, drop the heading and everything after it.
    """
    if not text:
        return text
    last = None
    for m in _REF_BLOCK_HEADING_RE.finditer(text):
        last = m
    if last is None:
        return text
    tail = text[last.start():]
    if _re.search(r"https?://", tail):
        return text[: last.start()].rstrip().rstrip(".,:;")
    return text


def _strip_urls(text):
    if not text:
        return text
    # 1) Trailing References/Sources block that contains URLs -> drop wholesale
    text = _strip_trailing_ref_block(text)
    # 2) Connector phrase + URL ("available at: <url>", "Source: url") -> drop both
    text = _URL_WITH_PREFIX_RE.sub("", text)
    # 3) Bracketed-numbered reference with URL: "[1] https://..." -> drop both
    text = _REF_BRACKET_URL_RE.sub("", text)
    # 4) Markdown links: keep anchor text, drop URL
    text = _MD_LINK_URL_RE.sub(r"\1", text)
    # 5) Angle-bracketed URLs: drop entirely
    text = _ANGLE_URL_RE.sub("", text)
    # 6) Bare URLs: drop
    text = _BARE_URL_RE.sub("", text)
    # 7) Cleanup: empty parens/brackets left behind
    text = _re.sub(r"\(\s*\)", "", text)
    text = _re.sub(r"\[\s*\]", "", text)
    # 8) Dangling connector phrases ("available at:") with no URL left
    text = _DANGLING_PREFIX_RE.sub("", text)
    text = _DANGLING_SOURCE_LINE_RE.sub("", text)
    # 9) Orphan bracketed reference numbers left behind
    text = _ORPHAN_REF_NUM_RE.sub("", text)
    return text


# ============================================================
# Response deduplication: the model sometimes loops, restarting
# a numbered list or repeating a paragraph. Detect that and
# truncate at the repetition boundary, then trim to the last
# complete sentence so the output reads cleanly.
# ============================================================
_NUMBERED_ITEM_RE = _re.compile(r"(?m)^\s*(\d{1,2})[.)]\s+")
_SENTENCE_END_RE  = _re.compile(r"[.!?](?=[\s\"'\)\]]|$)")
_WORD_RE = _re.compile(r"\w+")


def _normalize_for_compare(s):
    """Lowercase and collapse non-word runs so 'Foo. bar' matches 'foo bar'."""
    return _re.sub(r"\W+", " ", s.lower()).strip()


def _trim_to_last_sentence(text):
    """Trim trailing partial clause to the last complete sentence."""
    if not text:
        return text
    matches = list(_SENTENCE_END_RE.finditer(text))
    if not matches:
        return text.rstrip()
    return text[: matches[-1].end()].rstrip()


def _deduplicate_response(text):
    """Detect repeating paragraphs or list restarts and truncate."""
    if not text or len(text) < 200:
        return text

    # 1) Numbered-list restart: a second occurrence of a "1." opener on its
    #    own line, with the first one also visible, almost always means the
    #    model restarted the list. Cut before the second "1.".
    opener_ones = [m for m in _NUMBERED_ITEM_RE.finditer(text) if m.group(1) == "1"]
    if len(opener_ones) >= 2:
        cutoff = opener_ones[1].start()
        # Only treat as a restart if there was substantive content before it
        if cutoff > 120:
            return _trim_to_last_sentence(text[:cutoff])

    # 2) Paragraph-level duplication: if a paragraph (>= ~10 words) has a
    #    normalised 60-char prefix that already appears earlier in the
    #    normalised text, treat as a loop and cut at that paragraph.
    paragraphs = text.split("\n\n")
    if len(paragraphs) >= 2:
        running_norm = ""
        offset = 0  # character offset into the original text of this paragraph
        for i, para in enumerate(paragraphs):
            norm = _normalize_for_compare(para)
            word_count = len(_WORD_RE.findall(para))
            if word_count >= 10:
                key = norm[:60]
                if key and key in running_norm:
                    cut = offset
                    if cut > 120:
                        return _trim_to_last_sentence(text[:cut])
            running_norm += " " + norm
            offset += len(para) + 2  # +2 for the "\n\n" separator

    # 3) Numbered-item duplication across different numbers (e.g. item 4 is a
    #    rehash of item 2): compare normalised item bodies.
    items = list(_NUMBERED_ITEM_RE.finditer(text))
    if len(items) >= 3:
        bodies = []
        for idx, m in enumerate(items):
            start = m.end()
            end = items[idx + 1].start() if idx + 1 < len(items) else len(text)
            body = _normalize_for_compare(text[start:end])
            if len(body) < 40:
                bodies.append(body)
                continue
            key = body[:60]
            for prev in bodies:
                if key and key in prev:
                    cut = m.start()
                    if cut > 120:
                        return _trim_to_last_sentence(text[:cut])
            bodies.append(body)

    return text


def strip_filler_phrases(text):
    """Remove hedging/filler phrases, raw URLs, and loop-repetition from LLM output."""
    if not text:
        return text
    text = _strip_opening_meta_sentence(text)
    for pat in _FILLER_PATTERNS:
        text = pat.sub("", text)
    text = _strip_urls(text)
    text = _deduplicate_response(text)
    text = _re.sub(r" {2,}", " ", text)
    text = _re.sub(r"\s+([,.;:!?])", r"\1", text)
    text = _re.sub(r",\s*,+", ",", text)
    text = _re.sub(r"\.\s*\.+", ".", text)
    text = _re.sub(r"\n{3,}", "\n\n", text)
    text = _re.sub(r"^[\s.,;:]+", "", text)
    text = _re.sub(r"\s+\.\s+", ". ", text)
    return text
