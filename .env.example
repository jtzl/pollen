# ==================== App Settings ====================
APP_NAME=Pollen
PORT=5000

# ==================== Model Settings ====================
MODEL_REPO=mistralai/Mixtral-8x7B-Instruct-v0.1
MODEL_DISPLAY_NAME=Mixtral 8x7B Instruct
MODEL_BADGE=8x7B
# MODEL_CARD_URL=https://huggingface.co/mistralai/Mixtral-8x7B-Instruct-v0.1
# MODEL_LICENSE_URL=https://huggingface.co/mistralai/Mixtral-8x7B-Instruct-v0.1/blob/main/LICENSE
DEFAULT_MAX_TOKENS=500

# ==================== Network Settings ====================
# Comma-separated list of Petals DHT peer multiaddresses (required)
DHT_INITIAL_PEERS=/ip4/YOUR_IP/tcp/31337/p2p/YOUR_PEER_ID

# ==================== UI Settings ====================
SHOW_PETALS_BRANDING=true
WELCOME_MESSAGE=A powerful mixture-of-experts model running on a decentralized Petals network.
